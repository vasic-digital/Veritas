# Veritas .gitignore — CONST-053 compliance
# Forbidden classes: build artefacts, cache, temp, sensitive-data,
# generated reports/logs, OS/IDE personal state.

# --- build artefacts ---
/bin/
/build/
/dist/
/out/
target/
*.exe
*.dll
*.so
*.dylib
*.a
*.o
*.test
mutbin
challenges/runner/runner
challenges/runner/mutbin

# --- cache files ---
.cache/
.gocache/

# --- temp / scratch ---
*.tmp
*.swp
*.orig
*.rej
*~
.DS_Store
Thumbs.db

# --- sensitive-data ---
.env
.env.*
!.env.example
*.pem
*.key
*.crt
id_rsa*
id_ed25519*
.netrc
secrets/
api_keys.sh

# --- generated reports / logs ---
*.log
coverage.out
coverage.html
htmlcov/
*.out

# --- OS / IDE personal state ---
.idea/
.history/
.vscode/

# --- Go vendor (we use go.mod + replace, not vendor/) ---
/vendor/
